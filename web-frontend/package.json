{
  "name": "web-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build:dev": "dotenv -e ../.env.development -- react-router build",
    "build:prod": "dotenv -e ../.env.production -- react-router build",
    "build:test": "react-router build",
    "dev": "dotenv -e ../.env.development -- react-router dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "preview:dev": "dotenv -e ../.env.development -- react-router-serve ./build/server/index.js",
    "preview:prod": "dotenv -e ../.env.production -- react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@livekit/components-react": "^2.9.20",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-router/node": "^7.9.2",
    "@react-router/serve": "^7.9.2",
    "axios": "^1.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "isbot": "^5.1.31",
    "livekit-client": "^2.18.7",
    "lucide-react": "^0.546.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.65.0",
    "react-photo-view": "^1.2.7",
    "react-player": "^3.3.3",
    "react-router": "^7.9.2",
    "remix-hook-form": "^7.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "uuid": "^14.0.0",
    "valibot": "^1.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@react-router/dev": "^7.9.2",
    "@tailwindcss/vite": "^4.1.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^22",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/uuid": "^11.0.0",
    "dotenv-cli": "^11.0.0",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
