{
  "name": "bun-elysia-api",
  "version": "1.0.0",
  "private": true,
  "main": "src/main.ts",
  "scripts": {
    "build": "bun build src/main.ts --target bun --outdir ./dist",
    "build:binary": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server ./src/main.ts --external consolidate",
    "db:dev": "dotenv -e ../.env.development -- bun migrate:dev && bun seed:dev",
    "db:prod": "dotenv -e ../.env.production -- bun migrate:dev && bun seed:dev",
    "docker:down:dev": "docker compose --env-file ../.env.development -f ../docker-compose-db.yml down",
    "docker:down:prod": "docker compose --env-file ../.env.production -f ../docker-compose-db.yml down",
    "docker:up:dev": "docker compose --env-file ../.env.development -f ../docker-compose-db.yml up -d",
    "docker:up:prod": "docker compose --env-file ../.env.production -f ../docker-compose-db.yml up -d",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "generate": "bunx prisma generate",
    "generate:dev": "dotenv -e ../.env.development -- bunx prisma generate",
    "generate:prod": "dotenv -e ../.env.production -- bunx prisma generate",
    "lint": "eslint . --ext .js,.ts,.jsx,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.ts,.jsx,.tsx --max-warnings=0 --fix",
    "migrate:dev": "dotenv -e ../.env.development -- prisma migrate dev --schema ./prisma/schema.prisma && bun generate:dev",
    "migrate:dev:reset": "dotenv -e ../.env.development -- prisma migrate reset --schema ./prisma/schema.prisma",
    "migrate:prod": "dotenv -e ../.env.production -- prisma migrate dev --schema ./prisma/schema.prisma && bun generate:prod",
    "migrate:prod:reset": "dotenv -e ../.env.production -- prisma migrate reset --schema ./prisma/schema.prisma",
    "seed:dev": "dotenv -e ../.env.development -- bun ./prisma/seeder/seeder.ts",
    "seed:prod": "dotenv -e ../.env.production -- bun ./prisma/seeder/seeder.ts",
    "sort:package": "sort-package-json",
    "start": "dotenv -e ../.env.production -- NODE_ENV=production ./server",
    "start-deploy:dev": "dotenv -e ../.env.development -- ./server",
    "start:dev": "dotenv -e ../.env.development -- bun run --watch src/main.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "package.json": "bun sort:package",
    "src/**/*.ts": [
      "bun lint"
    ]
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/bearer": "^1.1.2",
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/jwt": "^1.1.1",
    "@elysiajs/swagger": "^1.1.6",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.5.0",
    "@yolk-oss/elysia-env": "^3.0.0",
    "bullmq": "^5.70.4",
    "csvtojson": "^2.0.10",
    "dayjs": "^1.11.19",
    "dotenv": "^17.0.0",
    "elysia": "^1.1.26",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "bun-types": "^1.1.39",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-code-style-lint-ts": "^3.1.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "2.30.0",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^52.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.2.5",
    "prisma": "^7.4.2",
    "sort-package-json": "^3.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "@swc/core",
    "esbuild",
    "prisma",
    "unrs-resolver"
  ]
}
