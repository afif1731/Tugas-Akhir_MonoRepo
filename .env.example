# Overall
ENV="development"
SERVER_HOST="moca-vision.com"

ADMIN_EMAIL="admin-moca@moca-vision.com"
ADMIN_NAME="Admin Moca"
ADMIN_PASSWORD="12345678"

USE_GLOBAL_VIOLENCE_THRESHOLD="false"
VIOLENCE_GLOBAL_CONFIDENCE_THRESHOLD="0.5"
VIOLENCE_ASSAULT_CONFIDENCE_THRESHOLD="0.5"
VIOLENCE_FIGHTING_CONFIDENCE_THRESHOLD="0.5"
VIOLENCE_ROBBERY_CONFIDENCE_THRESHOLD="0.5"
VIOLENCE_SHOOTING_CONFIDENCE_THRESHOLD="0.5"

# Protocol
WEB_HTTP_POROTOCOL="http"
LIVEKIT_HTTP_PROTOCOL="http"
LIVEKIT_WS_PROTOCOL="ws"
LIVEKIT_USE_EXTERNAL_IP="false"

# Port & Address
LIVEKIT_NODE_IP="127.0.0.1"
LIVEKIT_PORT="7880"

LIVEKIT_TCP_PORT="7881" # Used if you're using windows and network mode host is not available. you'll want to expose this port instead
LIVEKIT_UDP_PORT="7882" # Same with the top

FRONTEND_HOST="localhost"
FRONTEND_PORT="3000"

BACKEND_HOST="localhost"
BACKEND_PORT="4000"

POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"

REDIS_PORT="6379"

# LiveKit
LIVEKIT_YAML_FILE="livekit.yaml"

LIVEKIT_ROOM_NAME="surveillance_room"
LIVEKIT_API_KEY="dev_key"
LIVEKIT_API_SECRET="OO6yJSLvDojRa2vd1n1t4xwO0bs9hkk6oLlXDT4IYIRJMP7i"
LIVEKIT_DEVICE_SECRET="ZG1pVXpZD5A1hfKSJt0c6Yqf0GMSbjQVuEsefxMqcJzXBBJgifi0peUvcDYTHybN"

LIVEKIT_KEYS="${LIVEKIT_API_KEY}: ${LIVEKIT_API_SECRET}"
LIVEKIT_URL="${LIVEKIT_WS_PROTOCOL}://${LIVEKIT_NODE_IP}:${LIVEKIT_PORT}"
LIVEKIT_HTTP_URL="${LIVEKIT_HTTP_PROTOCOL}://${LIVEKIT_NODE_IP}:${LIVEKIT_PORT}"

# Livekit TURN Server
LIVEKIT_TURN_ENABLED="true"
LIVEKIT_TURN_DOMAIN="livekit.your-domain.com"
LIVEKIT_TURN_TLS_PORT="5349"
LIVEKIT_TURN_UDP_PORT="3478"
LIVEKIT_LETSENCRYPT_FOLDER="/etc/letsencrypt"
LIVEKIT_TURN_CERT_FILE="${LIVEKIT_LETSENCRYPT_FOLDER}/live/livekit.your-domain.com/fullchain.pem"
LIVEKIT_TURN_KEY_FILE="${LIVEKIT_LETSENCRYPT_FOLDER}/live/livekit.your-domain.com/privkey.pem"

# Node
NODE_ENV="${ENV}"

# Frontend
VITE_API_URL="${WEB_HTTP_POROTOCOL}://${BACKEND_HOST}:${BACKEND_PORT}"
VITE_LIVEKIT_URL="${LIVEKIT_URL}"

VITE_USE_GLOBAL_VIOLENCE_THRESHOLD="${USE_GLOBAL_VIOLENCE_THRESHOLD}"
VITE_VIOLENCE_GLOBAL_CONFIDENCE_THRESHOLD="${VIOLENCE_GLOBAL_CONFIDENCE_THRESHOLD}"
VITE_VIOLENCE_ASSAULT_CONFIDENCE_THRESHOLD="${VIOLENCE_ASSAULT_CONFIDENCE_THRESHOLD}"
VITE_VIOLENCE_FIGHTING_CONFIDENCE_THRESHOLD="${VIOLENCE_FIGHTING_CONFIDENCE_THRESHOLD}"
VITE_VIOLENCE_ROBBERY_CONFIDENCE_THRESHOLD="${VIOLENCE_ROBBERY_CONFIDENCE_THRESHOLD}"
VITE_VIOLENCE_SHOOTING_CONFIDENCE_THRESHOLD="${VIOLENCE_SHOOTING_CONFIDENCE_THRESHOLD}"

# Backend
FILE_STORAGE_PATH="../file-storage"
COOKIE_DOMAIN="${BACKEND_HOST}"

